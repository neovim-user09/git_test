<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add expiration date to the stock quant tree view (Add a line popup) -->
    <record id="view_stock_quant_tree_simple_inherit" model="ir.ui.view">
        <field name="name">stock.quant.tree.simple.inherit</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_simple"/>
        <field name="arch" type="xml">
            <field name="quantity" position="before">
                <field name="expiration_date" string="Expiration Date"/>
            </field>
        </field>
    </record>
</odoo>